# Postgres — Payload Postgres adapter.
# When running the app INSIDE docker compose (the default dev workflow), the DB
# host is the compose service name `db` — the app service's `environment:` in
# docker-compose.yml sets this for you:
#   DATABASE_URI=postgres://postgres:postgres@db:5432/kite_and_key
# If you ever run the app directly on the HOST instead, use localhost:
DATABASE_URI=postgres://postgres:postgres@localhost:5432/kite_and_key

# Payload — REQUIRED, random 32+ char string; generate with `openssl rand -hex 32`
PAYLOAD_SECRET=

# Public base URL (Payload serverURL + Next)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Seed script (dev only) — first admin credentials. No default password; the
# seed script refuses to run without these set.
SEED_ADMIN_EMAIL=admin@example.edu
SEED_ADMIN_PASSWORD=
# ALLOW_SEED=true   # set true only to force the seed script outside dev/NODE_ENV!=production
